{
  "name": "voltpilot-agent-demo",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "backend"
  ],
  "scripts": {
    "dev": "concurrently \"npm:dev:server\" \"npm:dev:client\"",
    "dev:client": "vite --host 127.0.0.1",
    "dev:server": "node --watch server.mjs",
    "build": "vite build",
    "test": "node --test backend/test/*.test.mjs",
    "validate:serverless": "node --check backend/api/index.mjs",
    "preview": "vite preview --host 127.0.0.1",
    "start": "node server.mjs"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^5.1.1",
    "vite": "^7.2.7",
    "typescript": "^5.9.3",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "lucide-react": "^0.561.0",
    "express": "^5.2.1",
    "cors": "^2.8.5",
    "dotenv": "^17.2.3"
  },
  "devDependencies": {
    "concurrently": "^9.2.1"
  }
}
